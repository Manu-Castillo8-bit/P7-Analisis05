<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P7_Analisis05.Poemas">
    
    <FlyoutPage.Flyout>
        <ContentPage Title="📚 Poema">
            <ScrollView>
                <VerticalStackLayout Spacing="10" Padding="10">
                    
                    <!-- Encabezado -->
                    <Frame BackgroundColor="#2C3E50" 
                           CornerRadius="10" 
                           Padding="15" 
                           Margin="0,0,0,20">
                        <VerticalStackLayout>
                            <Label Text="📖 Poesía Clásica" 
                                   FontSize="24" 
                                   FontAttributes="Bold" 
                                   TextColor="White" 
                                   HorizontalOptions="Center"/>
                            <Label Text="Un poema para ti" 
                                   FontSize="14" 
                                   TextColor="#BDC3C7" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Poema en el Flyout -->
                    <Frame BackgroundColor="#F8F9FA" 
                           CornerRadius="15" 
                           Padding="20"
                           Margin="0,10">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="🌹 Cultivo una rosa blanca" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#2C3E50"
                                   HorizontalOptions="Center"/>
                            
                            <Label Text="José Martí" 
                                   FontSize="14" 
                                   TextColor="#7F8C8D"
                                   HorizontalOptions="Center"/>
                            
                            <BoxView HeightRequest="1" 
                                     Color="#BDC3C7"/>
                            
                            <Label Text="Cultivo una rosa blanca
en junio como en enero,
para el amigo sincero
que me da su mano franca.

Y para el cruel que me arranca
el corazón con que vivo,
cardo ni ortiga cultivo,
cultivo la rosa blanca." 
                                   FontSize="14" 
                                   TextColor="#2C3E50"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Frame>
                    
                    <!-- Pie de página -->
                    <Label Text="© 2024 - Poesía Clásica" 
                           FontSize="12" 
                           TextColor="#95A5A6" 
                           HorizontalOptions="Center"
                           Margin="0,20,0,0"/>
                    
                </VerticalStackLayout>
            </ScrollView>
        </ContentPage>
    </FlyoutPage.Flyout>
    
    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage Title="📖 Poema">
                    <Grid>
                        <VerticalStackLayout Spacing="20" 
                                             Padding="20" 
                                             VerticalOptions="Center">
                            
                            <Label Text="🌹 Cultivo una rosa blanca" 
                                   FontSize="28" 
                                   FontAttributes="Bold" 
                                   HorizontalOptions="Center"
                                   TextColor="#2C3E50"/>
                            
                            <Label Text="✍️ José Martí" 
                                   FontSize="18" 
                                   HorizontalOptions="Center"
                                   TextColor="#7F8C8D"/>
                            
                            <BoxView HeightRequest="2" 
                                     Color="#3498DB" 
                                     HorizontalOptions="Center"
                                     WidthRequest="100"/>
                            
                            <Frame BackgroundColor="#F8F9FA" 
                                   CornerRadius="15" 
                                   Padding="20"
                                   Margin="0,20">
                                <Label Text="Cultivo una rosa blanca
en junio como en enero,
para el amigo sincero
que me da su mano franca.

Y para el cruel que me arranca
el corazón con que vivo,
cardo ni ortiga cultivo,
cultivo la rosa blanca." 
                                       FontSize="16" 
                                       TextColor="#2C3E50"
                                       LineBreakMode="WordWrap"/>
                            </Frame>
                            
                            <Label Text="☰ Toca el icono de menú para ver el poema" 
                                   FontSize="14" 
                                   TextColor="#95A5A6" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>
</FlyoutPage>